{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "MakeBuild",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceRoot}/debug/main",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                "description": "Enable pretty-printing for gdb",
                "text": "-enable-pretty-printing",
                "ignoreFailures": true
                }
            ],
            "preLaunchTask": "MakeBuild",
        }
    ]
}